# Production Environment Variables for Railway

# Node.js Configuration
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=4096

# Port Configuration (Railway will set this)
PORT=3000

# Meta API Configuration (REQUIRED)
NEXT_PUBLIC_META_ACCESS_TOKEN=your_meta_access_token_here
NEXT_PUBLIC_META_AD_ACCOUNT_ID=act_your_account_id_here

# Claude AI Configuration (Optional - for AI features)
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_claude_api_key_here

# API Configuration
NEXT_PUBLIC_API_URL=https://your-domain.railway.app
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true
NEXT_PUBLIC_ENABLE_AUTO_SYNC=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=false

# Performance
NEXT_PUBLIC_CACHE_TTL=300000
NEXT_PUBLIC_MAX_RETRIES=3

# Monitoring (Optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Security
NEXT_PUBLIC_CSRF_SECRET=generate_a_random_string_here

# Development/Debug (set to false in production)
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_SHOW_PERFORMANCE_METRICS=false