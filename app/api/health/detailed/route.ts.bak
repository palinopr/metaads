import { NextRequest, NextResponse } from 'next/server'\nimport fs from 'fs/promises'\nimport path from 'path'\n\ninterface HealthCheck {\n  status: 'healthy' | 'degraded' | 'unhealthy'\n  timestamp: string\n  uptime: number\n  version: string\n  environment: string\n  checks: {\n    [key: string]: {\n      status: 'pass' | 'fail' | 'warn'\n      duration?: number\n      error?: string\n      details?: any\n    }\n  }\n  metrics: {\n    memory: {\n      used: number\n      total: number\n      percentage: number\n    }\n    errors: {\n      total: number\n      rate: number\n      critical: number\n    }\n    performance: {\n      avgResponseTime: number\n      errorRate: number\n    }\n  }\n}\n\nexport async function GET(request: NextRequest) {\n  const startTime = Date.now()\n  \n  try {\n    const health: HealthCheck = {\n      status: 'healthy',\n      timestamp: new Date().toISOString(),\n      uptime: process.uptime(),\n      version: process.env.npm_package_version || '1.0.0',\n      environment: process.env.NODE_ENV || 'development',\n      checks: {},\n      metrics: {\n        memory: {\n          used: 0,\n          total: 0,\n          percentage: 0\n        },\n        errors: {\n          total: 0,\n          rate: 0,\n          critical: 0\n        },\n        performance: {\n          avgResponseTime: 0,\n          errorRate: 0\n        }\n      }\n    }\n\n    // Database connectivity check (if applicable)\n    health.checks.database = await checkDatabase()\n    \n    // File system check\n    health.checks.filesystem = await checkFileSystem()\n    \n    // Memory check\n    health.checks.memory = await checkMemory(health.metrics.memory)\n    \n    // Error logs check\n    health.checks.errorLogs = await checkErrorLogs(health.metrics.errors)\n    \n    // External API connectivity\n    health.checks.externalAPIs = await checkExternalAPIs()\n    \n    // Performance metrics\n    health.checks.performance = await checkPerformance(health.metrics.performance)\n    \n    // Determine overall status\n    const checkStatuses = Object.values(health.checks).map(check => check.status)\n    \n    if (checkStatuses.some(status => status === 'fail')) {\n      health.status = 'unhealthy'\n    } else if (checkStatuses.some(status => status === 'warn')) {\n      health.status = 'degraded'\n    } else {\n      health.status = 'healthy'\n    }\n    \n    // Add response time\n    const responseTime = Date.now() - startTime\n    health.checks.responseTime = {\n      status: responseTime < 1000 ? 'pass' : responseTime < 5000 ? 'warn' : 'fail',\n      duration: responseTime\n    }\n    \n    const statusCode = health.status === 'healthy' ? 200 : \n                      health.status === 'degraded' ? 200 : 503\n    \n    return NextResponse.json(health, { status: statusCode })\n    \n  } catch (error) {\n    console.error('Health check failed:', error)\n    \n    return NextResponse.json({\n      status: 'unhealthy',\n      timestamp: new Date().toISOString(),\n      error: (error as Error).message,\n      uptime: process.uptime()\n    }, { status: 503 })\n  }\n}\n\nasync function checkDatabase() {\n  const startTime = Date.now()\n  \n  try {\n    // For this project, we'll check if we can access the logs directory\n    // In a real application, this would check actual database connectivity\n    const logsDir = path.join(process.cwd(), 'logs')\n    await fs.access(logsDir)\n    \n    return {\n      status: 'pass' as const,\n      duration: Date.now() - startTime,\n      details: { connection: 'active' }\n    }\n  } catch (error) {\n    return {\n      status: 'fail' as const,\n      duration: Date.now() - startTime,\n      error: (error as Error).message\n    }\n  }\n}\n\nasync function checkFileSystem() {\n  const startTime = Date.now()\n  \n  try {\n    // Check if we can read/write to the file system\n    const testFile = path.join(process.cwd(), 'logs', '.health-check')\n    const testData = `Health check: ${new Date().toISOString()}`\n    \n    await fs.writeFile(testFile, testData)\n    const content = await fs.readFile(testFile, 'utf8')\n    await fs.unlink(testFile)\n    \n    return {\n      status: content === testData ? 'pass' as const : 'fail' as const,\n      duration: Date.now() - startTime\n    }\n  } catch (error) {\n    return {\n      status: 'fail' as const,\n      duration: Date.now() - startTime,\n      error: (error as Error).message\n    }\n  }\n}\n\nasync function checkMemory(metrics: HealthCheck['metrics']['memory']) {\n  const startTime = Date.now()\n  \n  try {\n    const memUsage = process.memoryUsage()\n    \n    metrics.used = memUsage.heapUsed\n    metrics.total = memUsage.heapTotal\n    metrics.percentage = (memUsage.heapUsed / memUsage.heapTotal) * 100\n    \n    const status = metrics.percentage < 80 ? 'pass' : \n                  metrics.percentage < 95 ? 'warn' : 'fail'\n    \n    return {\n      status,\n      duration: Date.now() - startTime,\n      details: {\n        heapUsed: memUsage.heapUsed,\n        heapTotal: memUsage.heapTotal,\n        rss: memUsage.rss,\n        external: memUsage.external,\n        percentage: metrics.percentage\n      }\n    }\n  } catch (error) {\n    return {\n      status: 'fail' as const,\n      duration: Date.now() - startTime,\n      error: (error as Error).message\n    }\n  }\n}\n\nasync function checkErrorLogs(metrics: HealthCheck['metrics']['errors']) {\n  const startTime = Date.now()\n  \n  try {\n    const logsDir = path.join(process.cwd(), 'logs')\n    const today = new Date().toISOString().split('T')[0]\n    const errorLogFile = path.join(logsDir, `errors-${today}.json`)\n    \n    try {\n      const logContent = await fs.readFile(errorLogFile, 'utf8')\n      const errors = JSON.parse(logContent)\n      \n      metrics.total = errors.length\n      \n      // Count critical errors\n      metrics.critical = errors.filter((error: any) => \n        error.severity === 'critical' || error.type === 'unhandled_rejection'\n      ).length\n      \n      // Calculate error rate (errors per hour)\n      const oneHourAgo = Date.now() - (60 * 60 * 1000)\n      const recentErrors = errors.filter((error: any) => \n        new Date(error.timestamp).getTime() > oneHourAgo\n      )\n      metrics.rate = recentErrors.length\n      \n      const status = metrics.critical > 0 ? 'fail' : \n                    metrics.rate > 50 ? 'warn' : 'pass'\n      \n      return {\n        status,\n        duration: Date.now() - startTime,\n        details: {\n          totalErrors: metrics.total,\n          criticalErrors: metrics.critical,\n          recentErrors: metrics.rate\n        }\n      }\n    } catch (fileError) {\n      // No error log file means no errors (good)\n      return {\n        status: 'pass' as const,\n        duration: Date.now() - startTime,\n        details: { message: 'No error logs found' }\n      }\n    }\n  } catch (error) {\n    return {\n      status: 'warn' as const,\n      duration: Date.now() - startTime,\n      error: (error as Error).message\n    }\n  }\n}\n\nasync function checkExternalAPIs() {\n  const startTime = Date.now()\n  const checks: Record<string, any> = {}\n  \n  // Check Meta API (if token is available)\n  if (process.env.META_ACCESS_TOKEN) {\n    try {\n      const response = await fetch('https://graph.facebook.com/me?fields=id', {\n        headers: {\n          'Authorization': `Bearer ${process.env.META_ACCESS_TOKEN}`\n        },\n        signal: AbortSignal.timeout(5000)\n      })\n      \n      checks.metaAPI = {\n        status: response.ok ? 'pass' : 'fail',\n        statusCode: response.status\n      }\n    } catch (error) {\n      checks.metaAPI = {\n        status: 'fail' as const,\n        error: (error as Error).message\n      }\n    }\n  } else {\n    checks.metaAPI = {\n      status: 'warn' as const,\n      error: 'No Meta access token configured'\n    }\n  }\n  \n  const overallStatus = Object.values(checks).some((check: any) => check.status === 'fail') ? 'fail' :\n                       Object.values(checks).some((check: any) => check.status === 'warn') ? 'warn' : 'pass'\n  \n  return {\n    status: overallStatus,\n    duration: Date.now() - startTime,\n    details: checks\n  }\n}\n\nasync function checkPerformance(metrics: HealthCheck['metrics']['performance']) {\n  const startTime = Date.now()\n  \n  try {\n    // In a real application, you'd calculate these from actual metrics\n    // For now, we'll use placeholder values\n    metrics.avgResponseTime = 150 // ms\n    metrics.errorRate = 0.5 // percentage\n    \n    const status = metrics.avgResponseTime < 500 && metrics.errorRate < 5 ? 'pass' :\n                  metrics.avgResponseTime < 1000 && metrics.errorRate < 10 ? 'warn' : 'fail'\n    \n    return {\n      status,\n      duration: Date.now() - startTime,\n      details: {\n        avgResponseTime: metrics.avgResponseTime,\n        errorRate: metrics.errorRate\n      }\n    }\n  } catch (error) {\n    return {\n      status: 'fail' as const,\n      duration: Date.now() - startTime,\n      error: (error as Error).message\n    }\n  }\n}"