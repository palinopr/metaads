# Meta API Configuration
# Get your access token from: https://developers.facebook.com/tools/explorer/
# Required permissions: ads_management, ads_read, business_management
NEXT_PUBLIC_META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE
NEXT_PUBLIC_META_AD_ACCOUNT_ID=act_YOUR_ACCOUNT_ID_HERE

# Claude AI Configuration (optional)
# Get your API key from: https://console.anthropic.com/
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true
NEXT_PUBLIC_ENABLE_AUTO_SYNC=false

# Performance
NEXT_PUBLIC_CACHE_TTL=300000
NEXT_PUBLIC_MAX_RETRIES=3

# Development
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_SHOW_PERFORMANCE_METRICS=false