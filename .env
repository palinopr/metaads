# Meta API Configuration
NEXT_PUBLIC_META_ACCESS_TOKEN=
NEXT_PUBLIC_META_AD_ACCOUNT_ID=

# Claude AI Configuration (optional)
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true
NEXT_PUBLIC_ENABLE_AUTO_SYNC=false

# Performance
NEXT_PUBLIC_CACHE_TTL=300000
NEXT_PUBLIC_MAX_RETRIES=3

# Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Development
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_SHOW_PERFORMANCE_METRICS=false